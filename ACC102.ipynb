# ======================================================
# Track 2 经济数据分析：中国宏观经济指标分析
# 数据源：World Bank 公开数据格式（已内置稳定数据）
# 特点：无需联网、无需API、100%可直接运行
# ======================================================

import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# --------------------------
# 1. 内置真实格式的经济数据（无需联网）
# --------------------------
print("=== 加载经济数据 ===")

# 世界银行公开数据格式（中国GDP、CPI、进出口 2000-2024）
data = {
    "Year": list(range(2000, 2025)),
    "GDP": [
        1.2e12, 1.33e12, 1.47e12, 1.64e12, 1.94e12, 2.29e12, 2.75e12, 3.55e12,
        4.59e12, 5.11e12, 6.09e12, 7.55e12, 8.53e12, 9.57e12, 10.48e12, 11.06e12,
        11.23e12, 12.31e12, 13.89e12, 14.28e12, 14.69e12, 17.73e12, 18.10e12,
        17.96e12, 18.30e12
    ],
    "CPI": [
        0.4, 0.7, -0.8, 1.2, 3.9, 1.8, 1.5, 4.8, 5.9, -0.7, 3.3, 5.4, 2.6,
        2.6, 2.0, 1.4, 2.0, 1.6, 2.1, 2.9, 2.5, 0.9, 2.0, 0.2, 0.5
    ],
    "Exports": [
        249.2e9, 266.1e9, 325.6e9, 438.4e9, 593.3e9, 762.0e9, 969.1e9,
        1.22e12, 1.43e12, 1.20e12, 1.58e12, 1.90e12, 2.05e12, 2.21e12,
        2.34e12, 2.27e12, 2.10e12, 2.26e12, 2.48e12, 2.50e12, 2.69e12,
        3.36e12, 3.59e12, 3.38e12, 3.40e12
    ]
}

df = pd.DataFrame(data)

# --------------------------
# 2. 数据清洗（作业必备步骤）
# --------------------------
print("=== 数据清洗 ===")

# 检查缺失值
print("缺失值数量：")
print(df.isnull().sum())

# 去除缺失值（模拟真实数据处理）
df = df.dropna()

# 计算GDP增长率
df["GDP_Growth_Rate"] = df["GDP"].pct_change() * 100

# 计算进出口占GDP比例
df["Export_to_GDP"] = df["Exports"] / df["GDP"] * 100

# 清洗后数据预览
print("\n清洗后数据预览：")
print(df.head())

# --------------------------
# 3. 经济数据分析（核心部分）
# --------------------------
print("\n===== 经济指标分析 =====")
print("描述性统计：")
print(df.describe())

# 计算关键经济指标
avg_gdp_growth = df["GDP_Growth_Rate"].mean()
avg_cpi = df["CPI"].mean()
gdp_cpi_corr = df["GDP"].corr(df["CPI"])

print(f"\n年均GDP增长率：{avg_gdp_growth:.2f}%")
print(f"年均CPI通胀率：{avg_cpi:.2f}%")
print(f"GDP与CPI相关系数：{gdp_cpi_corr:.2f}")

# --------------------------
# 4. 可视化（作业必须有图）
# --------------------------
plt.rcParams["figure.figsize"] = (14, 10)
plt.rcParams["font.sans-serif"] = ["DejaVu Sans"]

fig, axes = plt.subplots(2, 2, figsize=(14, 10))

# 子图1：GDP增长趋势
axes[0,0].plot(df["Year"], df["GDP"] / 1e12, color="#1f77b4", linewidth=2)
axes[0,0].set_title("China GDP Trend (2000-2024)", fontsize=14)
axes[0,0].set_xlabel("Year")
axes[0,0].set_ylabel("GDP (Trillion USD)")
axes[0,0].grid(alpha=0.3)

# 子图2：CPI通胀率趋势
axes[0,1].plot(df["Year"], df["CPI"], color="#ff7f0e", linewidth=2)
axes[0,1].set_title("China CPI Inflation Rate (2000-2024)", fontsize=14)
axes[0,1].set_xlabel("Year")
axes[0,1].set_ylabel("CPI (%)")
axes[0,1].grid(alpha=0.3)

# 子图3：GDP增长率分布
axes[1,0].hist(df["GDP_Growth_Rate"].dropna(), bins=10, color="#2ca02c", alpha=0.7)
axes[1,0].set_title("GDP Growth Rate Distribution", fontsize=14)
axes[1,0].set_xlabel("Growth Rate (%)")
axes[1,0].grid(alpha=0.3)

# 子图4：出口占GDP比例趋势
axes[1,1].plot(df["Year"], df["Export_to_GDP"], color="#d62728", linewidth=2)
axes[1,1].set_title("Export-to-GDP Ratio Trend", fontsize=14)
axes[1,1].set_xlabel("Year")
axes[1,1].set_ylabel("Export/GDP (%)")
axes[1,1].grid(alpha=0.3)

plt.tight_layout()
plt.show()

# --------------------------
# 5. 数据处理完成提示（已修复保存权限问题）
# --------------------------
print("\n✅ 数据处理、分析、可视化已全部完成！")
print("✅ 如需保存CSV文件，可使用 df.to_csv() 命令保存到本地可写目录（如下载文件夹）")
print("✅ 经济数据分析完成！")
